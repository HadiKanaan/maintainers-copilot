# Vault
VAULT_ROOT_TOKEN=<your_vault_root_token>
VAULT_ADDR=<vault_address>

# Postgres
POSTGRES_PASSWORD=<postgres_password>
DATABASE_URL=<database_url>
REDIS_URL=<redis_url>

# MinIO
MINIO_ROOT_USER=<minio_root_user>
MINIO_ROOT_PASSWORD=<minio_root_password>
MINIO_ENDPOINT=<minio_endpoint>

# Azure OpenAI (these values are stored in Vault in production)
AZURE_OPENAI_API_KEY=<azure_openai_api_key>
AZURE_OPENAI_ENDPOINT=<azure_openai_endpoint>
AZURE_OPENAI_DEPLOYMENT_NAME=<azure_openai_deployment_name>
AZURE_OPENAI_API_VERSION=<azure_openai_api_version>
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=<azure_openai_embedding_deployment>

# LangSmith
LANGSMITH_API_KEY=<langsmith_api_key>
LANGSMITH_PROJECT=<langsmith_project>

# JWT
JWT_SECRET_KEY=<jwt_secret_key>

# Modelserver
MODELSERVER_URL=<modelserver_url>

# Classifier artifacts (MinIO)
CLASSIFIER_BUCKET=<classifier_bucket>
CLASSIFIER_WEIGHTS_KEY=<classifier_weights_key>

# GitHub
GITHUB_REPO=<owner/repo>
GITHUB_TOKEN=<github_token>
